{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Clean Running Game",
            "command": "taskkill /f /im strategy.exe 2>nul & exit 0",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "C/C++: g++.exe build active file with cleanup",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "dependsOn": [
                "Clean Running Game"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Safely unlocks background executables and runs a clean compilation."
        }
    ]
}